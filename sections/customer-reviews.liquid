

<script
  src="{{ 'customer-reviews.js' | asset_url }}"
  type="module"
></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<customer-reviews
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style customer-reviews"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="customer-reviews"
>
  <div class="customer-reviews__header">
    <div class="customer-reviews__summary">
      {%- if section.settings.heading != blank -%}
        <h2 class="customer-reviews__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {% content_for 'block', type: 'review', id: 'rating' %}
    </div>

    <div class="customer-reviews__controls">
      <div class="customer-reviews__sort-wrapper">
        <label
          class="customer-reviews__sort-label"
          for="CustomerReviewsSort-{{ section.id }}"
        >
          Sort by
        </label>
        <select
          class="customer-reviews__sort select"
          id="CustomerReviewsSort-{{ section.id }}"
          ref="sortSelect"
          on:change="/handleSortChange"
        >
          <option value="recent">Most recent</option>
          <option value="highest">Highest rated</option>
          <option value="lowest">Lowest rated</option>
        </select>
      </div>

      {% content_for 'block', type: 'button', id: 'write-review' %}
    </div>
  </div>

  <div
    class="customer-reviews__grid"
    ref="grid"
  >
    {% content_for 'blocks' %}
  </div>
</customer-reviews>

{% stylesheet %}
  .customer-reviews__header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    margin-block-end: var(--margin-lg);
  }

  .customer-reviews__heading {
    margin: 0 0 var(--margin-2xs);
  }

  .customer-reviews__controls {
    display: flex;
    align-items: center;
    gap: var(--gap-md);
    flex-wrap: wrap;
  }

  .customer-reviews__sort-wrapper {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
  }

  .customer-reviews__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--gap-md);
  }

  @media screen and (min-width: 750px) {
    .customer-reviews__grid {
      grid-template-columns: repeat(var(--customer-reviews-columns, 2), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer reviews",
  "class": "shopify-section--customer-reviews",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "review"
    },
    {
      "type": "button"
    },
    {
      "type": "_review-card"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer reviews"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Customer reviews",
      "category": "Storytelling",
      "blocks": {
        "rating": {
          "type": "review",
          "static": true,
          "settings": {
            "stars_style": "shaded",
            "show_number": true,
            "type_preset": "h5"
          }
        },
        "write-review": {
          "type": "button",
          "static": true,
          "settings": {
            "label": "Write a review",
            "style_class": "button-secondary"
          }
        },
        "review-1": {
          "type": "_review-card",
          "settings": {
            "author_name": "Jordan M.",
            "rating": "5",
            "date": "2 weeks ago",
            "title": "Worked from day one",
            "body": "<p>Setup was simple and my dog learned the boundary within a few days. Couldn't be happier.</p>"
          }
        },
        "review-2": {
          "type": "_review-card",
          "settings": {
            "author_name": "Priya S.",
            "rating": "5",
            "date": "1 month ago",
            "title": "Great peace of mind",
            "body": "<p>We have two dogs with very different temperaments and this worked for both. Customer support was responsive too.</p>"
          }
        },
        "review-3": {
          "type": "_review-card",
          "settings": {
            "author_name": "Alex T.",
            "rating": "4",
            "date": "2 months ago",
            "title": "Solid, with a short learning curve",
            "body": "<p>Took about a week of training flags before our dog respected the boundary, but it has held up well since.</p>"
          }
        }
      },
      "block_order": ["review-1", "review-2", "review-3"]
    }
  ]
}
{% endschema %}
