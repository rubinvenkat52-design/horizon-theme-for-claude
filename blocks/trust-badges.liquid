

{% liquid
  assign s = block.settings
%}

<div class="trust-badges" {{ block.shopify_attributes }}>
  {%- for i in (1..3) -%}
    {%- liquid
      assign icon_key    = 'icon_' | append: i
      assign img_key     = 'icon_image_' | append: i
      assign heading_key = 'heading_' | append: i
      assign subtext_key = 'subtext_' | append: i

      assign badge_icon    = s[icon_key]
      assign badge_image   = s[img_key]
      assign badge_heading = s[heading_key]
      assign badge_subtext = s[subtext_key]
    -%}

    {%- if i > 1 and s.show_dividers -%}
      <span class="trust-badges__divider" aria-hidden="true"></span>
    {%- endif -%}

    <div class="trust-badge">
      <div class="trust-badge__icon">
        {%- render 'icon-or-image',
          icon: badge_icon,
          image_upload: badge_image,
          width: s.icon_size
        -%}
      </div>
      {%- if badge_heading != blank or badge_subtext != blank -%}
        <div class="trust-badge__content">
          {%- if badge_heading != blank -%}
            <p class="trust-badge__heading">{{ badge_heading }}</p>
          {%- endif -%}
          {%- if badge_subtext != blank -%}
            <p class="trust-badge__subtext">{{ badge_subtext }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

{% stylesheet %}
  .trust-badges {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: var(--gap-sm);
    padding: var(--padding-sm) 0;
  }

  .trust-badges__divider {
    width: 1px;
    background: rgb(var(--color-foreground-rgb) / 0.12);
    flex-shrink: 0;
    align-self: stretch;
  }

  .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-2xs);
    flex: 1;
    text-align: center;
  }

  .trust-badge__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
  }

  .trust-badge__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-badge__heading {
    font-size: var(--font-paragraph-small--size);
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
    margin: 0;
    color: var(--color-foreground);
  }

  .trust-badge__subtext {
    font-size: calc(var(--font-paragraph-small--size) * 0.9);
    line-height: 1.3;
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }
{% endstylesheet %}

