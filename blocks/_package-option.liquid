

{% liquid
  assign block_settings = block.settings
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif

  assign matched_variant = blank
  for product_variant in product_resource.variants
    if product_variant.options contains block_settings.variant_option_value
      assign matched_variant = product_variant
      break
    endif
  endfor

  assign savings_amount = 0
  if matched_variant != blank and matched_variant.compare_at_price > matched_variant.price
    assign savings_amount = matched_variant.compare_at_price | minus: matched_variant.price
  endif
%}

<button
  type="button"
  class="package-option{% if block_settings.highlight %} package-option--highlighted{% endif %}"
  data-option-value="{{ block_settings.variant_option_value | escape }}"
  data-variant-id="{{ matched_variant.id }}"
  role="radio"
  aria-checked="false"
  on:click="/selectPackage"
  {{ block.shopify_attributes }}
>
  {%- if block_settings.corner_tag_text != blank -%}
    <span class="package-option__corner-tag">{{ block_settings.corner_tag_text }}</span>
  {%- endif -%}

  {%- if block_settings.highlight and block_settings.ribbon_text != blank -%}
    <span class="package-option__ribbon">{{ block_settings.ribbon_text }}</span>
  {%- endif -%}

  <span class="package-option__main">
    {%- if block_settings.image -%}
      <span class="package-option__image">
        {{
          block_settings.image
          | image_url: width: 160
          | image_tag: loading: 'lazy', widths: '80, 120, 160'
        }}
      </span>
    {%- endif -%}

    <span class="package-option__info">
      <span class="package-option__title">{{ block_settings.title }}</span>
      {%- if block_settings.subtitle != blank -%}
        <span class="package-option__subtitle">{{ block_settings.subtitle }}</span>
      {%- endif -%}
      {%- if savings_amount > 0 -%}
        <span class="package-option__savings">Save {{ savings_amount | money }}</span>
      {%- endif -%}
    </span>

    {%- if matched_variant != blank -%}
      <span class="package-option__price-stack">
        <span class="package-option__price-now">{{ matched_variant.price | money }}</span>
        {%- if matched_variant.compare_at_price > matched_variant.price -%}
          <s class="package-option__price-compare">{{ matched_variant.compare_at_price | money }}</s>
        {%- endif -%}
      </span>
    {%- endif -%}
  </span>

  <span class="package-option__perks">
    {% content_for 'blocks' %}
  </span>
</button>

{% stylesheet %}
  .package-option {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: var(--style-border-width) solid var(--color-border);
    border-radius: var(--style-border-radius-md);
    background: var(--color-background);
    cursor: pointer;
    font: inherit;
    color: inherit;
    text-align: left;
    padding: 0;
    transition: border-color var(--animation-speed, 0.2s) ease, box-shadow var(--animation-speed, 0.2s) ease;
  }

  .package-option:hover {
    border-color: var(--color-primary);
  }

  .package-option--active {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary);
  }

  .package-option--highlighted {
    border-color: var(--color-primary);
  }

  .package-option__corner-tag {
    position: absolute;
    top: var(--margin-2xs);
    right: var(--margin-2xs);
    padding: var(--padding-3xs) var(--padding-2xs);
    border-radius: var(--style-border-radius-xs);
    background: var(--color-foreground-mix-background-15, rgba(0, 0, 0, 0.08));
    font-size: var(--font-paragraph-small--size);
    font-weight: var(--font-weight-bold);
    white-space: nowrap;
  }

  .package-option__ribbon {
    position: absolute;
    top: var(--margin-xs);
    right: calc(-1 * var(--margin-2xl, 32px));
    transform: rotate(45deg);
    width: 9em;
    padding: var(--padding-3xs) 0;
    background: var(--color-primary);
    color: var(--color-background);
    font-size: var(--font-paragraph-small--size);
    font-weight: var(--font-weight-bold);
    text-align: center;
    text-transform: uppercase;
  }

  .package-option__main {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    padding: var(--padding-lg);
  }

  .package-option__image img {
    display: block;
    width: 100%;
    max-width: 4.5rem;
    height: auto;
    border-radius: var(--style-border-radius-sm);
  }

  .package-option__info {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--gap-4xs, 2px);
    min-width: 0;
  }

  .package-option__title {
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-paragraph--size);
  }

  .package-option__subtitle {
    opacity: var(--opacity-80, 0.8);
    font-size: var(--font-paragraph-small--size);
  }

  .package-option__savings {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-paragraph-small--size);
  }

  .package-option__price-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
    gap: var(--gap-4xs, 2px);
  }

  .package-option__price-now {
    font-weight: var(--font-weight-bold);
    font-size: var(--font-h6--size, var(--font-paragraph--size));
  }

  .package-option__price-compare {
    opacity: var(--opacity-80, 0.8);
    font-size: var(--font-paragraph-small--size);
  }

  .package-option__perks {
    display: flex;
    flex-direction: column;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Package option",
  "tag": null,
  "blocks": [
    {
      "type": "_package-perk"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "variant_option_value",
      "label": "Matching variant option value",
      "info": "Must exactly match one of this product's variant option values, e.g. \"2 Dogs\".",
      "default": "1 Dog"
    },
    {
      "type": "checkbox",
      "id": "highlight",
      "label": "Highlight as most popular",
      "default": false
    },
    {
      "type": "text",
      "id": "ribbon_text",
      "label": "Ribbon text (shown when highlighted)",
      "default": "Most popular"
    },
    {
      "type": "text",
      "id": "corner_tag_text",
      "label": "Corner tag text",
      "info": "Small label in the top-right corner, e.g. \"+ Free gifts\"."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "For 1 Dog"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Perfect for a single dog household"
    }
  ],
  "presets": [
    {
      "name": "Package option"
    }
  ]
}
{% endschema %}
