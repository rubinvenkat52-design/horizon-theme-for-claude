

<script
  src="{{ 'key-metrics.js' | asset_url }}"
  type="module"
></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<key-metrics
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style key-metrics"
  style="
    {%- render 'spacing-style', settings: section.settings %}
    --key-metrics-columns: {{ section.settings.columns }};
  "
  data-testid="key-metrics"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="key-metrics__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="key-metrics__grid">
    {% content_for 'blocks' %}
  </div>
</key-metrics>

{% stylesheet %}
  .key-metrics__heading {
    text-align: center;
    margin: 0 0 var(--margin-lg);
  }

  .key-metrics__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-lg);
  }

  @media screen and (min-width: 750px) {
    .key-metrics__grid {
      grid-template-columns: repeat(var(--key-metrics-columns, 3), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Impact statistics",
  "tag": null,
  "class": "shopify-section--key-metrics",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_stat-item"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Impact statistics",
      "category": "Storytelling",
      "blocks": {
        "stat-1": {
          "type": "_stat-item",
          "settings": {
            "value": "92",
            "suffix": "%",
            "label": "Customers report calmer walks within 2 weeks"
          }
        },
        "stat-2": {
          "type": "_stat-item",
          "settings": {
            "value": "10000",
            "suffix": "+",
            "label": "Happy dogs protected"
          }
        },
        "stat-3": {
          "type": "_stat-item",
          "settings": {
            "value": "4.8",
            "decimals": 1,
            "suffix": "/5",
            "label": "Average customer rating"
          }
        }
      },
      "block_order": ["stat-1", "stat-2", "stat-3"]
    }
  ]
}
{% endschema %}
