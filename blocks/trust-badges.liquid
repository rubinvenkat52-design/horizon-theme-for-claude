
{% liquid
  assign s = block.settings
%}

<div class="trust-badges" {{ block.shopify_attributes }}>

  <div class="trust-badge">
    <div class="trust-badge__icon">
      {%- render 'icon-or-image', icon: s.icon_1, image_upload: s.icon_image_1, width: s.icon_size -%}
    </div>
    {%- if s.heading_1 != blank or s.subtext_1 != blank -%}
      <div class="trust-badge__content">
        {%- if s.heading_1 != blank -%}
          <p class="trust-badge__heading">{{ s.heading_1 }}</p>
        {%- endif -%}
        {%- if s.subtext_1 != blank -%}
          <p class="trust-badge__subtext">{{ s.subtext_1 }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if s.show_dividers -%}
    <span class="trust-badges__divider" aria-hidden="true"></span>
  {%- endif -%}

  <div class="trust-badge">
    <div class="trust-badge__icon">
      {%- render 'icon-or-image', icon: s.icon_2, image_upload: s.icon_image_2, width: s.icon_size -%}
    </div>
    {%- if s.heading_2 != blank or s.subtext_2 != blank -%}
      <div class="trust-badge__content">
        {%- if s.heading_2 != blank -%}
          <p class="trust-badge__heading">{{ s.heading_2 }}</p>
        {%- endif -%}
        {%- if s.subtext_2 != blank -%}
          <p class="trust-badge__subtext">{{ s.subtext_2 }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if s.show_dividers -%}
    <span class="trust-badges__divider" aria-hidden="true"></span>
  {%- endif -%}

  <div class="trust-badge">
    <div class="trust-badge__icon">
      {%- render 'icon-or-image', icon: s.icon_3, image_upload: s.icon_image_3, width: s.icon_size -%}
    </div>
    {%- if s.heading_3 != blank or s.subtext_3 != blank -%}
      <div class="trust-badge__content">
        {%- if s.heading_3 != blank -%}
          <p class="trust-badge__heading">{{ s.heading_3 }}</p>
        {%- endif -%}
        {%- if s.subtext_3 != blank -%}
          <p class="trust-badge__subtext">{{ s.subtext_3 }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

</div>

{% stylesheet %}
  .trust-badges {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: var(--gap-sm);
    padding: var(--padding-sm) 0;
  }

  .trust-badges__divider {
    width: 1px;
    background: rgb(var(--color-foreground-rgb) / 0.12);
    flex-shrink: 0;
    align-self: stretch;
  }

  .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-2xs);
    flex: 1;
    text-align: center;
  }

  .trust-badge__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
  }

  .trust-badge__content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-badge__heading {
    font-size: var(--font-paragraph-small--size);
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
    margin: 0;
    color: var(--color-foreground);
  }

  .trust-badge__subtext {
    font-size: calc(var(--font-paragraph-small--size) * 0.9);
    line-height: 1.3;
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }
{% endstylesheet %}

{% schema %}
{
