
{% liquid assign s = block.settings %}

<div
  class="feature-boxes"
  {{ block.shopify_attributes }}
  style="
    --fb-bg: {{ s.box_bg_color }};
    --fb-text: {{ s.box_text_color }};
    --fb-radius: {{ s.box_radius }}px;
    --fb-icon-size: {{ s.icon_size }}px;
  "
>

  <div class="feature-box">
    <div class="feature-box__icon">
      {%- render 'icon-or-image', icon: s.icon_1, image_upload: s.icon_image_1, width: s.icon_size -%}
    </div>
    <div class="feature-box__content">
      {%- if s.heading_1 != blank -%}<p class="feature-box__heading">{{ s.heading_1 }}</p>{%- endif -%}
      {%- if s.subtext_1 != blank -%}<p class="feature-box__subtext">{{ s.subtext_1 }}</p>{%- endif -%}
    </div>
  </div>

  <div class="feature-box">
    <div class="feature-box__icon">
      {%- render 'icon-or-image', icon: s.icon_2, image_upload: s.icon_image_2, width: s.icon_size -%}
    </div>
    <div class="feature-box__content">
      {%- if s.heading_2 != blank -%}<p class="feature-box__heading">{{ s.heading_2 }}</p>{%- endif -%}
      {%- if s.subtext_2 != blank -%}<p class="feature-box__subtext">{{ s.subtext_2 }}</p>{%- endif -%}
    </div>
  </div>

  <div class="feature-box">
    <div class="feature-box__icon">
      {%- render 'icon-or-image', icon: s.icon_3, image_upload: s.icon_image_3, width: s.icon_size -%}
    </div>
    <div class="feature-box__content">
      {%- if s.heading_3 != blank -%}<p class="feature-box__heading">{{ s.heading_3 }}</p>{%- endif -%}
      {%- if s.subtext_3 != blank -%}<p class="feature-box__subtext">{{ s.subtext_3 }}</p>{%- endif -%}
    </div>
  </div>

</div>

<script src="{{ 'product-swipe-hint.js' | asset_url }}" defer></script>

{% stylesheet %}

.feature-boxes {
  display: flex;
  flex-direction: column;
  gap: 8px;
  width: 100%;
}

.feature-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14px;
  padding: 13px 16px;
  background-color: var(--fb-bg, #1a3a2a);
  border-radius: var(--fb-radius, 8px);
  color: var(--fb-text, #fff);
}

.feature-box__icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fb-text, #fff);
}

.feature-box__icon svg,
.feature-box__icon img {
  width: var(--fb-icon-size, 32px);
  height: var(--fb-icon-size, 32px);
  display: block;
  object-fit: contain;
  color: var(--fb-text, #fff);
  fill: var(--fb-text, #fff);
}

.feature-box__content {
  flex: 1;
  min-width: 0;
}

.feature-box__heading {
  font-size: var(--font-paragraph-small--size, 0.875rem);
  font-weight: var(--font-weight-semibold, 600);
  line-height: 1.3;
  margin: 0;
  color: var(--fb-text, #fff);
}

.feature-box__subtext {
  font-size: calc(var(--font-paragraph-small--size, 0.875rem) * 0.88);
  line-height: 1.3;
  margin: 0;
  margin-top: 2px;
  color: rgb(255 255 255 / 0.7);
}

/* Hide default carousel arrows — replaced by swipe hint */
.product-information__media media-gallery .slideshow-arrows {
  display: none !important;
}

/* ── Hero layout (Perfect template) ── */

/*
 * Before JS runs, the feature-boxes block is an additional section block
 * rendered BELOW the product grid as a direct child of .product-information.
 * Hide it initially to prevent a flash before JS repositions it.
 */
.product-information > .feature-boxes {
  display: none !important;
}

/*
 * After JS moves .feature-boxes into .pih-boxes-column inside the media div,
 * reveal it and apply the side-by-side layout.
 */

/* Media div: flex row when it contains the boxes column */
[data-testid="product-information-media"]:has(.pih-boxes-column) {
  display: flex !important;
  gap: 6px;
  align-items: stretch;
  min-width: 0;
}

/* Gallery wrapper — ~62% of the media column */
.pih-gallery-wrapper {
  flex: 62;
  min-width: 0;
  overflow: hidden;
}

/* Boxes column — ~38% of the media column */
.pih-boxes-column {
  flex: 38;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.pih-boxes-column .feature-boxes {
  display: flex !important;  /* override the hide above */
  flex: 1;
  height: 100%;
  gap: 6px;
  justify-content: space-between;
}

/* Each box: icon on top, text below, centered */
.pih-boxes-column .feature-box {
  flex: 1;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center;
  text-align: center;
  padding: 10px 8px;
  gap: 6px;
  min-height: 0;
}

.pih-boxes-column .feature-box__content {
  align-items: center;
}

.pih-boxes-column .feature-box__icon svg,
.pih-boxes-column .feature-box__icon img {
  width: 24px !important;
  height: 24px !important;
}

/* Mobile tweaks */
@media screen and (max-width: 749px) {
  [data-testid="product-information-media"]:has(.pih-boxes-column) {
    gap: 4px;
  }

  .pih-boxes-column .feature-box {
    padding: 6px 4px;
    gap: 3px;
  }

  .pih-boxes-column .feature-box__icon svg,
  .pih-boxes-column .feature-box__icon img {
    width: 18px !important;
    height: 18px !important;
  }

  .pih-boxes-column .feature-box__heading {
    font-size: 0.58rem;
    line-height: 1.15;
    font-weight: 700;
  }

  .pih-boxes-column .feature-box__subtext {
    display: none;
  }
}

/* Desktop tweaks */
@media screen and (min-width: 750px) {
  .pih-boxes-column .feature-box {
    padding: 14px 10px;
    gap: 8px;
  }

  .pih-boxes-column .feature-box__icon svg,
  .pih-boxes-column .feature-box__icon img {
    width: 28px !important;
    height: 28px !important;
  }

  .pih-boxes-column .feature-box__heading {
    font-size: var(--font-paragraph-small--size, 0.8rem);
    line-height: 1.25;
  }

  .pih-boxes-column .feature-box__subtext {
    display: block;
    font-size: calc(var(--font-paragraph-small--size, 0.8rem) * 0.82);
  }
}

/* ---- Swipe hint overlay ---- */
.product-swipe-hint {
  position: absolute;
  top: 50%;
  z-index: 10;
  pointer-events: none;
  opacity: 0;
  transform: translateY(-50%);
}

.product-swipe-hint--right {
  right: 14px;
  animation: psh-slide-left 1.8s cubic-bezier(0.4, 0, 0.6, 1) forwards;
}

.product-swipe-hint--left {
  left: 14px;
  animation: psh-slide-right 1.8s cubic-bezier(0.4, 0, 0.6, 1) forwards;
}

.product-swipe-hint__pill {
  background: rgba(0, 0, 0, 0.52);
  backdrop-filter: blur(4px);
  border-radius: 50%;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

@keyframes psh-slide-left {
  0%   { opacity: 0;   transform: translateY(-50%) translateX(0); }
  18%  { opacity: 1;   transform: translateY(-50%) translateX(0); }
  72%  { opacity: 0.9; transform: translateY(-50%) translateX(-24px); }
  100% { opacity: 0;   transform: translateY(-50%) translateX(-24px); }
}

@keyframes psh-slide-right {
  0%   { opacity: 0;   transform: translateY(-50%) translateX(0); }
  18%  { opacity: 1;   transform: translateY(-50%) translateX(0); }
  72%  { opacity: 0.9; transform: translateY(-50%) translateX(24px); }
  100% { opacity: 0;   transform: translateY(-50%) translateX(24px); }
}

@media (prefers-reduced-motion: reduce) {
  .product-swipe-hint { display: none; }
}

{% endstylesheet %}

