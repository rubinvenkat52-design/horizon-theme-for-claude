        { "value": "box",       "label": "Box" },
        { "value": "lock",      "label": "Lock" },
        { "value": "check_box", "label": "Check" },
        { "value": "star",      "label": "Star" },
        { "value": "return",    "label": "Return" },
        { "value": "recycle",   "label": "Recycle" },
        { "value": "heart",     "label": "Heart" },
        { "value": "leaf",      "label": "Leaf" }
      ],
      "default": "truck"
    },
    {
      "type": "image_picker",
      "id": "icon_image_1",
      "label": "Custom icon image"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading",
      "default": "Free Shipping"
    },
    {
      "type": "text",
      "id": "subtext_1",
      "label": "Subtext",
      "default": "On orders over $50"
    },
    {
      "type": "header",
      "content": "Guarantee"
    },
    {
      "type": "select",
      "id": "icon_2",
      "label": "Icon",
      "options": [
        { "value": "none",      "label": "None" },
        { "value": "truck",     "label": "Truck" },
        { "value": "plane",     "label": "Plane" },
        { "value": "box",       "label": "Box" },
        { "value": "lock",      "label": "Lock" },
        { "value": "check_box", "label": "Check" },
        { "value": "star",      "label": "Star" },
        { "value": "return",    "label": "Return" },
        { "value": "recycle",   "label": "Recycle" },
        { "value": "heart",     "label": "Heart" },
        { "value": "leaf",      "label": "Leaf" }
      ],
      "default": "star"
    },
    {
      "type": "image_picker",
      "id": "icon_image_2",
      "label": "Custom icon image"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading",
      "default": "Money-Back Guarantee"
    },
    {
      "type": "text",
      "id": "subtext_2",
      "label": "Subtext",
      "default": "30-day guarantee"
    },
    {
      "type": "header",
      "content": "Returns"
    },
    {
      "type": "select",
      "id": "icon_3",
      "label": "Icon",
      "options": [
        { "value": "none",      "label": "None" },
        { "value": "truck",     "label": "Truck" },
        { "value": "plane",     "label": "Plane" },
        { "value": "box",       "label": "Box" },
        { "value": "lock",      "label": "Lock" },
        { "value": "check_box", "label": "Check" },
        { "value": "star",      "label": "Star" },
        { "value": "return",    "label": "Return" },
        { "value": "recycle",   "label": "Recycle" },
        { "value": "heart",     "label": "Heart" },
        { "value": "leaf",      "label": "Leaf" }
      ],
      "default": "return"
    },
    {
      "type": "image_picker",
      "id": "icon_image_3",
      "label": "Custom icon image"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Heading",
      "default": "Easy Returns"
    },
    {
      "type": "text",
      "id": "subtext_3",
