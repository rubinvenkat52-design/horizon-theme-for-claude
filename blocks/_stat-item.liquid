

{% liquid
  assign block_settings = block.settings
%}

<div
  class="stat-item"
  data-stat-target="{{ block_settings.value }}"
  data-stat-decimals="{{ block_settings.decimals }}"
  data-stat-prefix="{{ block_settings.prefix | escape }}"
  data-stat-suffix="{{ block_settings.suffix | escape }}"
  {{ block.shopify_attributes }}
>
  <p class="stat-item__number">
    <span data-stat-number>{{ block_settings.prefix }}{{ block_settings.value }}{{ block_settings.suffix }}</span>
  </p>
  <p class="stat-item__label">{{ block_settings.label }}</p>
</div>

{% stylesheet %}
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--gap-2xs);
  }

  .stat-item__number {
    margin: 0;
    font-size: var(--font-h1--size);
    font-weight: var(--font-weight-bold);
    line-height: 1;
  }

  .stat-item__label {
    margin: 0;
    font-size: var(--font-paragraph--size);
    opacity: var(--opacity-80, 0.8);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Stat",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "value",
      "label": "Number",
      "default": "92"
    },
    {
      "type": "range",
      "id": "decimals",
      "label": "Decimal places",
      "min": 0,
      "max": 2,
      "step": 1,
      "default": 0
    },
    {
      "type": "text",
      "id": "prefix",
      "label": "Prefix",
      "default": ""
    },
    {
      "type": "text",
      "id": "suffix",
      "label": "Suffix",
      "default": "%"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Customers report calmer walks"
    }
  ],
  "presets": [
    {
      "name": "Stat"
    }
  ]
}
{% endschema %}
